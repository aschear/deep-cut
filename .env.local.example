# ── AudD API ────────────────────────────────────────────────────────────────
# Get your key at https://dashboard.audd.io/
# Without this key the app returns a mock song (for local development only).
AUDD_API_KEY=your_audd_api_key_here

# ── Anthropic API ────────────────────────────────────────────────────────────
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here
